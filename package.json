{
  "name": "whatsappd",
  "version": "0.2.0",
  "description": "A self-hosted daemon that turns a WhatsApp number into an AI-agent channel — Baileys engine, HTTP sidecar, agent tools, and an Eve adapter.",
  "keywords": [
    "agent-tools",
    "ai-agents",
    "ai-sdk",
    "baileys",
    "chatbot",
    "daemon",
    "eve",
    "llm",
    "sidecar",
    "typescript",
    "whatsapp",
    "whatsapp-api",
    "whatsapp-bot"
  ],
  "homepage": "https://github.com/AaronAbuUsama/whatsappd#readme",
  "bugs": {
    "url": "https://github.com/AaronAbuUsama/whatsappd/issues"
  },
  "license": "MIT",
  "author": "Aaron AbuUsama <security@abuusama.dev>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AaronAbuUsama/whatsappd.git"
  },
  "bin": {
    "whatsappd": "./bin/whatsappd.js"
  },
  "files": [
    "dist",
    "bin",
    "CHANGELOG.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./adapters/eve": "./dist/adapters/eve.mjs",
    "./sidecar": "./dist/sidecar/index.mjs",
    "./stores/libsql": "./dist/stores/libsql.mjs",
    "./stores/memory": "./dist/stores/memory.mjs",
    "./tools": "./dist/tools/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "node --experimental-strip-types --test tests/*.test.ts",
    "check": "vp check",
    "proof": "node --experimental-strip-types tests/proof.ts",
    "prepublishOnly": "vp run build",
    "prepare": "vp config"
  },
  "dependencies": {
    "baileys": "7.0.0-rc13",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@libsql/client": "0.15.15",
    "@types/node": "^25.6.2",
    "@types/qrcode-terminal": "^0.12.2",
    "@typescript/native-preview": "7.0.0-dev.20260509.2",
    "eve": "^0.21.1",
    "typescript": "^6.0.3",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "@libsql/client": "^0.15.0",
    "eve": ">=0.21.0 <1"
  },
  "peerDependenciesMeta": {
    "@libsql/client": {
      "optional": true
    },
    "eve": {
      "optional": true
    }
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.10.0",
      "onFail": "download"
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@11.10.0"
}
